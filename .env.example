# Configuración para API de TheSportsDB
# Key pública de prueba: 123
# Puedes obtener tu API key en: https://www.thesportsdb.com
THESPORTSDB_API_KEY=078593

# football-data.org — utilizado para otras integraciones opcionales
FOOTBALL_DATA_API_KEY=

# 12.3 — Clave de acceso para la API REST local (X-API-Key)
# Si no se define, la API funciona sin autenticación (modo desarrollo).
# Genera una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
API_REST_KEY=

# Restricción de acceso al bot por membresía a grupo de Telegram
# Obtén el ID del grupo con: /start en @userinfobot dentro del grupo, o leyendo el campo id de getUpdates.
# Deja vacío para deshabilitar la restricción (cualquier usuario puede usar el bot).
ALLOWED_GROUP_ID=

# Modo mantenimiento del bot de Telegram (RoadmapBotTelegram #17)
# Si está definida, todos los handlers (excepto /start) responden con este mensaje y no ejecutan lógica.
# Útil para anunciar cierres planificados sin apagar el bot.
# Déjalo vacío para modo normal.
BOT_MAINTENANCE_MSG=

# Modo debug para usuarios técnicos del dashboard
# Si está a true/1/yes, aparece el expander "Datos en bruto (JSON)" en cada informe.
# Dejar en blanco o false para ocultarlo en producción.
BETA_DEBUG=

# Modo oscuro para gráficos de matplotlib (RoadmapDashboard #15)
# Si está a true/1/yes, los gráficos utilizan el estilo dark_background.
# También se detecta automáticamente desde .streamlit/config.toml si existe.
# Dejar en blanco para modo claro (defecto).
STREAMLIT_DARK_MODE=