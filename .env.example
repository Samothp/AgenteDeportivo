# Configuración para API de TheSportsDB
# Key pública de prueba: 123
# Puedes obtener tu API key en: https://www.thesportsdb.com
THESPORTSDB_API_KEY=078593

# football-data.org — utilizado para otras integraciones opcionales
FOOTBALL_DATA_API_KEY=

# 12.3 — Clave de acceso para la API REST local (X-API-Key)
# Si no se define, la API funciona sin autenticación (modo desarrollo).
# Genera una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
API_REST_KEY=

# Restricción de acceso al bot por membresía a grupo de Telegram
# Obtén el ID del grupo con: /start en @userinfobot dentro del grupo, o leyendo el campo id de getUpdates.
# Deja vacío para deshabilitar la restricción (cualquier usuario puede usar el bot).
ALLOWED_GROUP_ID=