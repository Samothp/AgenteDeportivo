{% extends "base.html.j2" %}

{% block title %}Jornada {{ jornada }}{% endblock %}

{% block extra_style %}
    .metrics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; }
    .metric { background: white; padding: 16px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .score { font-size: 1.2em; font-weight: bold; text-align: center; }
    th, td { text-align: left; }
    th { text-align: left; }
{% endblock %}

{% block content %}
  <h1>Jornada {{ jornada }}</h1>
  {% if season %}
  <p><strong>Temporada:</strong> {{ season }}
     &nbsp; <strong>Partidos disputados:</strong> {{ num_partidos }}</p>
  {% endif %}

  <div class="section">
    <h2>Estadísticas de la jornada</h2>
    <div class="metrics-grid">
      <div class="metric"><strong>Goles totales</strong>
        <p style="font-size:1.4em;font-weight:bold">{{ total_goals }}</p></div>
      <div class="metric"><strong>Goles por partido</strong>
        <p style="font-size:1.4em;font-weight:bold">{{ "%.2f"|format(avg_goals) }}</p></div>
      {% if total_yellow is not none %}
      <div class="metric"><strong>Tarjetas amarillas</strong>
        <p style="font-size:1.4em;font-weight:bold">{{ total_yellow }}</p></div>
      {% endif %}
      {% if total_red is not none %}
      <div class="metric"><strong>Tarjetas rojas</strong>
        <p style="font-size:1.4em;font-weight:bold">{{ total_red }}</p></div>
      {% endif %}
      {% if avg_possession_local is not none %}
      <div class="metric"><strong>Posesión media local</strong>
        <p>{{ "%.1f"|format(avg_possession_local) }}%</p></div>
      <div class="metric"><strong>Posesión media visitante</strong>
        <p>{{ "%.1f"|format(avg_possession_visitante) }}%</p></div>
      {% endif %}
    </div>
  </div>

  <div class="section">
    <h2>Resultados</h2>
    <table>
      <thead><tr><th>Local</th><th class="score">Marcador</th><th>Visitante</th><th>Tipo</th></tr></thead>
      <tbody>
      {% for r in results %}
        <tr style="background:{{ r.bg }}">
          <td><strong>{{ r.local }}</strong></td>
          <td class="score">{{ r.goles_local }} - {{ r.goles_visitante }}</td>
          <td><strong>{{ r.visitante }}</strong></td>
          <td>{{ r.label }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>

  {% if most_exciting or xg_surprise %}
  <div class="section">
    <h2>Datos destacados</h2>
    {% if most_exciting %}
    <p><strong>Partido más espectacular:</strong>
      {{ most_exciting.local }}
      <strong>{{ most_exciting.goles_local }} - {{ most_exciting.goles_visitante }}</strong>
      {{ most_exciting.visitante }}
      <em>({{ most_exciting.goles_totales }} goles)</em>
    </p>
    {% endif %}
    {% if xg_surprise %}
    <p><strong>Sorpresa de la jornada (resultado vs xG):</strong>
      {{ xg_surprise.local }}
      <strong>{{ xg_surprise.goles_local }} - {{ xg_surprise.goles_visitante }}</strong>
      {{ xg_surprise.visitante }} &mdash;
      xG esperado: {{ xg_surprise.local[:15] }}
      <em>{{ xg_surprise.xg_local }}</em> - <em>{{ xg_surprise.xg_visitante }}</em>
      {{ xg_surprise.visitante[:15] }}
    </p>
    {% endif %}
  </div>
  {% endif %}

  {% if standings_html %}
  <div class="section">
    <h2>Clasificación tras la jornada {{ jornada }}</h2>
    {{ standings_html | safe }}
  </div>
  {% endif %}

  {% if images %}
  <div class="section">
    <h2>Gráficos</h2>
    {% for img in images %}
    <img src="{{ img }}" alt="Gráfico jornada {{ jornada }}">
    {% endfor %}
  </div>
  {% endif %}
{% endblock %}
